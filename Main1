    now = int(time.time())
    if now - last < 86400:
        remaining = 86400 - (now - last)
        await callback.answer(f"❌ Бонус раз в 24ч. Осталось {remaining//3600}ч {(remaining%3600)//60}мин.", show_alert=True)
        return
    bonus = random.randint(1, 10)
    await update_balance(uid, bonus)
    await set_last_daily_bonus(uid, now)
    await callback.answer(f"✅ Вы получили {bonus} ⭐!", show_alert=True)
    await callback.answer()

