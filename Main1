    if not code.isalnum():
        return await message.answer("❌ Код должен содержать только буквы и цифры. Попробуйте ещё раз.")
    existing = await get_promo_by_code(code)
    if existing:
        return await message.answer("❌ Такой промокод уже существует. Введите другой.")
    await state.update_data(code=code)
