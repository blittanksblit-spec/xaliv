@router.callback_query(F.data.startswith("c_"))
async def open_case(callback: CallbackQuery, bot: Bot):
    if await check_banned_callback(callback): return
    key = callback.data.replace("c_", "")
    case = CASES[key]
    uid = callback.from_user.id
    if key == "free":
        last_time = await get_last_free_case(uid)
        now = int(time.time())
        if now - last_time < 86400:
            remaining = 86400 - (now - last_time)
            return await callback.answer(f"❌ Бесплатный кейс раз в 24ч.\nСледующая попытка через: {remaining//3600}ч {(remaining%3600)//60}мин", show_alert=True)
        await set_last_free_case(uid, now)
    if case["cost"] > 0 and uid != ADMIN_ID:
        if await get_balance(uid) < case["cost"]: return await callback.answer("❌ Недостаточно звёзд!", show_alert=True)
        await update_balance(uid, -case["cost"])
    items = case["items"]
    msg = await callback.message.edit_text("🎲 Крутим...")
    await animate_case_opening(msg, items)
    prize = random.choices(items, weights=case["weights"], k=1)[0]
    if "⭐" in prize:
        val = int(prize.split()[1])
        await update_balance(uid, val)
        await safe_edit_text(msg, f"✅ Выпало: {prize}!", reply_markup=main_kb())
    elif prize == "💨 Пусто":
        await safe_edit_text(msg, "💨 Пусто! Повезёт в следующий раз.", reply_markup=main_kb())
    else:
        await add_gift_to_inventory(uid, prize)
        await safe_edit_text(msg, f"🎁 ОГО! Твой приз: {prize}\nОн отправлен в твой инвентарь!", reply_markup=main_kb())
    await callback.answer()

