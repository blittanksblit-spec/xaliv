    success = await send_gift_to_user(bot, uid, gift_name, "")
    if success:
        await remove_gift_from_inventory(uid, gift_name)
        if not has_withdrawn:
            await set_first_gift_withdrawn(uid)
        await safe_edit_text(callback.message, f"✅ <b>Подарок {gift_name} успешно выведен!</b>", reply_markup=main_kb(), parse_mode="HTML")
        await bot.send_message(ADMIN_ID, f"📤 <b>Вывод подарка из инвентаря</b>\n👤 <a href='tg://user?id={uid}'>{callback.from_user.first_name}</a>\n🎁 {gift_name}", parse_mode="HTML")
    else:
        await callback.answer("❌ Не удалось отправить подарок. Попробуйте позже.", show_alert=True)
    await callback.answer()

