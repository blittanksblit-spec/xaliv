@router.message(PromoState.waiting_for_code)
async def promo_activate(message: Message, state: FSMContext, bot: Bot):
    code = message.text.strip().upper()
    uid = message.from_user.id
    promo = await get_promo_by_code(code)
    if not promo:
        await message.answer("❌ Промокод не найден или недействителен.")
        await state.clear()
        return
    if promo["used_count"] >= promo["max_uses"]:
        await message.answer("❌ Промокод больше не действителен.")
        await state.clear()
        return
    if await has_activated_promo(uid, promo["id"]):
        await message.answer("❌ Вы уже активировали этот промокод.")
        await state.clear()
        return
    await activate_promo(uid, promo["id"])
    if promo["reward_type"] == "stars":
        await update_balance(uid, promo["reward_amount"])
        await message.answer(f"✅ Промокод активирован! Вы получили {promo['reward_amount']} ⭐.")
    elif promo["reward_type"] == "gift":
        await add_gift_to_inventory(uid, promo["reward_gift"])
        await message.answer(f"✅ Промокод активирован! Подарок «{promo['reward_gift']}» добавлен в инвентарь.")
        await bot.send_message(ADMIN_ID, f"🎟️ Пользователь <a href='tg://user?id={uid}'>{message.from_user.first_name}</a> активировал промокод {code} – {promo['reward_gift']}", parse_mode="HTML")
    await state.clear()

