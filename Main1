@router.message(CrashState.waiting_for_bet)
async def crash_bet(message: Message, state: FSMContext):
    uid = message.from_user.id
    if await is_user_banned(uid): await state.clear(); return await message.answer("⛔ Вы заблокированы.")
    try: bet = int(message.text); assert bet >= 5
    except: return await message.answer("❌ Введите целое число не менее 5!")
    if await get_balance(uid) < bet: await state.clear(); return await message.answer("❌ Недостаточно звёзд!")
    await update_balance(uid, -bet)
    crash_point = round(random.uniform(1.0, 10.0), 2)
    active_crash_games[uid] = {"bet": bet, "multiplier": 1.0, "crash_point": crash_point, "active": True}
    kb = InlineKeyboardMarkup(inline_keyboard=[[InlineKeyboardButton(text="💰 Забрать", callback_data="crash_cashout")]])
    await message.answer(f"📈 <b>Краш-игра началась!</b>\nСтавка: {bet} ⭐\nТекущий множитель: <b>1.00x</b>\n\nНажимайте «Забрать», пока не крашнулось!", parse_mode="HTML", reply_markup=kb)
    await state.clear()

@router.callback_query(F.data == "crash_cashout")
async def crash_cashout(callback: CallbackQuery):
    uid = callback.from_user.id
    if uid not in active_crash_games or not active_crash_games[uid]["active"]:
        return await callback.answer("❌ Игра не найдена или уже завершена!", show_alert=True)
    game = active_crash_games[uid]
    game["active"] = False
    win_amount = int(game["bet"] * game["multiplier"])
    await update_balance(uid, win_amount)
    await callback.message.edit_text(f"✅ <b>Вы забрали выигрыш!</b>\nСтавка: {game['bet']} ⭐\nМножитель: {game['multiplier']:.2f}x\nВыигрыш: <b>{win_amount} ⭐</b>", parse_mode="HTML")
    del active_crash_games[uid]
    await callback.answer()

