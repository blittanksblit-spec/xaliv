async def safe_edit_text(message, text, reply_markup=None, parse_mode=None):
    try:
        await message.edit_text(text, reply_markup=reply_markup, parse_mode=parse_mode)
    except TelegramBadRequest as e:
        if "message is not modified" not in str(e):
            raise

async def check_banned_callback(callback: CallbackQuery):
    if await is_user_banned(callback.from_user.id):
        await callback.answer("⛔ Вы заблокированы!", show_alert=True)
        return True
    return False

async def send_gift_to_user(bot: Bot, user_id: int, gift_name: str, user_name: str = ""):
    if gift_name not in GIFT_INFO:
        return False
    gift_data = GIFT_INFO[gift_name]
    gift_id = gift_data["id"]
    gift_price = gift_data["win_price"]
    bot_balance = await get_bot_balance()
    if bot_balance < gift_price:
        return False
    try:
        await update_bot_balance(-gift_price)
        gift_text = f"🎁 Подарок от {user_name}: {gift_name}!" if user_name else f"🎁 Вы получили подарок: {gift_name}!"
        await bot.send_gift(user_id=user_id, gift_id=gift_id, pay_for_upgrade=False, text=gift_text)
        return True
    except Exception as e:
        await update_bot_balance(gift_price)
        logger.error(f"Ошибка отправки подарка: {e}")
        return False

