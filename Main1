@router.callback_query(F.data.startswith("game_"))
async def play_game(callback: CallbackQuery, state: FSMContext):
    if await check_banned_callback(callback): return
    uid = callback.from_user.id
    game_id = callback.data
    game = next(g for g in GAMES if g["id"] == game_id)
    if game["id"] == "game_crash":
        await callback.message.answer("📈 <b>Краш-игра</b>\nВведите ставку в звёздах (минимум 5⭐):", parse_mode="HTML")
        await state.set_state(CrashState.waiting_for_bet)
        await callback.answer()
        return
    if game["id"] == "game_guess":
        await callback.message.answer("🔢 <b>Угадай число от 1 до 5</b>\nВведите ставку (минимум 5⭐):", parse_mode="HTML")
        await state.set_state(GuessState.waiting_for_bet)
        await callback.answer()
        return
    if uid != ADMIN_ID:
        if await get_balance(uid) < 5: return await callback.answer("❌ Не хватает звёзд!", show_alert=True)
        await update_balance(uid, -5)
    msg = await callback.message.answer_dice(emoji=game["emoji"])
    await asyncio.sleep(4)
    value = msg.dice.value
    win_amount = 0
    if game["emoji"] == "🎲" and value >= 4: win_amount = 10
    elif game["emoji"] == "🎯":
        if value == 6: win_amount = 15
        elif value >= 4: win_amount = 7
    elif game["emoji"] == "🎰":
        if value == 6: win_amount = 50
