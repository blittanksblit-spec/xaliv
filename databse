async def create_promo(code: str, reward_type: str, reward_amount: int, reward_gift: str, max_uses: int, created_by: int):
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute(
            "INSERT INTO promos (code, reward_type, reward_amount, reward_gift, max_uses, used_count, created_by, created_at) VALUES (?, ?, ?, ?, ?, 0, ?, ?)",
            (code, reward_type, reward_amount, reward_gift, max_uses, created_by, int(time.time()))
        )
        await db.commit()

async def get_promo_by_code(code: str):
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute(
            "SELECT id, reward_type, reward_amount, reward_gift, max_uses, used_count FROM promos WHERE code = ?",
            (code,)
        ) as cursor:
            row = await cursor.fetchone()
            if row:
                return {
                    "id": row[0],
                    "reward_type": row[1],
                    "reward_amount": row[2],
                    "reward_gift": row[3],
                    "max_uses": row[4],
                    "used_count": row[5]
                }
            return None

async def has_activated_promo(user_id: int, promo_id: int) -> bool:
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute(
            "SELECT 1 FROM promo_activations WHERE user_id = ? AND promo_id = ?",
            (user_id, promo_id)
        ) as cursor:
            row = await cursor.fetchone()
            return row is not None

async def activate_promo(user_id: int, promo_id: int):
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute(
            "INSERT INTO promo_activations (user_id, promo_id, activated_at) VALUES (?, ?, ?)",
            (user_id, promo_id, int(time.time()))
        )
        await db.execute(
            "UPDATE promos SET used_count = used_count + 1 WHERE id = ?",
            (promo_id,)
        )
        await db.commit()
