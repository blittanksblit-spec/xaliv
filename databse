import aiosqlite
import random
import time

DB_PATH = "casino9.db"

async def init_db():
    async with aiosqlite.connect(DB_PATH) as db:
        # Таблица пользователей
        await db.execute('''
            CREATE TABLE IF NOT EXISTS users (
                user_id INTEGER PRIMARY KEY,
                balance INTEGER DEFAULT 0,
                total_deposited INTEGER DEFAULT 0,
                first_gift_withdrawn BOOLEAN DEFAULT FALSE
            )
        ''')
        await db.commit()
        await _add_column_if_not_exists(db, "users", "ton_balance", "REAL DEFAULT 0")
        await _add_column_if_not_exists(db, "users", "referrer_id", "INTEGER")
        await _add_column_if_not_exists(db, "users", "referral_count", "INTEGER DEFAULT 0")
        await _add_column_if_not_exists(db, "users", "bonus_claimed", "BOOLEAN DEFAULT FALSE")
        await _add_column_if_not_exists(db, "users", "last_free_case", "INTEGER DEFAULT 0")
        await _add_column_if_not_exists(db, "users", "is_banned", "BOOLEAN DEFAULT FALSE")
        await _add_column_if_not_exists(db, "users", "last_daily_bonus", "INTEGER DEFAULT 0")
        await _add_column_if_not_exists(db, "users", "total_deposited", "INTEGER DEFAULT 0")
        await _add_column_if_not_exists(db, "users", "first_gift_withdrawn", "BOOLEAN DEFAULT FALSE")

        # Таблица инвентаря
        await db.execute('''
            CREATE TABLE IF NOT EXISTS inventory (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER NOT NULL,
                gift_name TEXT NOT NULL,
                UNIQUE(user_id, gift_name)
            )
        ''')
        await db.commit()

        # Таблица для баланса бота
        await db.execute('''
            CREATE TABLE IF NOT EXISTS bot_config (
                id INTEGER PRIMARY KEY CHECK (id = 1),
                stars_balance INTEGER DEFAULT 0
            )
        ''')
        await db.execute('''
            INSERT OR IGNORE INTO bot_config (id, stars_balance) VALUES (1, 0)
        ''')
        await db.commit()

        # Таблицы для промокодов
        await db.execute('''
            CREATE TABLE IF NOT EXISTS promos (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                code TEXT UNIQUE NOT NULL,
                reward_type TEXT NOT NULL,
                reward_amount INTEGER DEFAULT 0,
                reward_gift TEXT,
                max_uses INTEGER NOT NULL,
                used_count INTEGER DEFAULT 0,
                created_by INTEGER NOT NULL,
                created_at INTEGER NOT NULL
            )
        ''')
        await db.execute('''
            CREATE TABLE IF NOT EXISTS promo_activations (
                user_id INTEGER NOT NULL,
                promo_id INTEGER NOT NULL,
                activated_at INTEGER NOT NULL,
                PRIMARY KEY (user_id, promo_id)
            )
        ''')
        await db.commit()

async def _add_column_if_not_exists(db, table, column, column_type):
    cursor = await db.execute(f"PRAGMA table_info({table})")
    columns = [row[1] for row in await cursor.fetchall()]
    if column not in columns:
        await db.execute(f"ALTER TABLE {table} ADD COLUMN {column} {column_type}")
        await db.commit()

# ------------------- Балансы -------------------
async def get_balance(user_id: int) -> int:
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute("SELECT balance FROM users WHERE user_id = ?", (user_id,)) as cursor:
            row = await cursor.fetchone()
            return row[0] if row else 0

async def get_ton_balance(user_id: int) -> float:
